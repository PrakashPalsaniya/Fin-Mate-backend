# Database
MONGO_URI=mongodb://localhost:27017/expense-tracker

# App
PORT=5000
CLIENT_URL=http://localhost:3000

# JWT / Session
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=7d
SESSION_SECRET=your-session-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Email (Brevo)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_NAME=FinMate
BREVO_SENDER_EMAIL=your-verified-sender@example.com

# Redis
# Use REDIS_URL for hosted Redis, or REDIS_HOST/REDIS_PORT for local Redis.
# Set REDIS_DISABLED=true on deployments where Redis is optional and not provisioned.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DISABLED=false
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_MAX_RETRIES=3

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter (Telegram transaction parsing only)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=FinMate
TELEGRAM_PARSER_USE_OPENROUTER=true
TELEGRAM_PARSER_OPENROUTER_MODEL=openai/gpt-4o-mini
TELEGRAM_PARSER_OPENROUTER_COOLDOWN_MS=60000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=your-random-secret
TELEGRAM_LINK_CODE_TTL_SECONDS=600
TELEGRAM_PENDING_INTENT_TTL_SECONDS=900
TELEGRAM_PROCESSED_UPDATE_TTL_SECONDS=86400

# Summary Scheduler
SUMMARY_SCHEDULER_ENABLED=true
SUMMARY_SCHEDULER_INTERVAL_MS=60000
SUMMARY_DELIVERY_RETRY_COOLDOWN_MS=900000
