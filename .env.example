# Core
NODE_ENV=development
PORT=5000
JSON_BODY_LIMIT=100kb
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://localhost:27017/expense-tracker

# Auth
JWT_SECRET=replace-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
OTP_TTL_SECONDS=300
OAUTH_CODE_TTL_SECONDS=300
GOOGLE_OAUTH_STATE_TTL_SECONDS=300

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Email (Brevo)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_NAME=FinMate
BREVO_SENDER_EMAIL=your-verified-sender@example.com

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DISABLED=false
REDIS_REQUIRED_IN_PRODUCTION=true
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_MAX_RETRIES=3
RATE_LIMIT_FAIL_OPEN=true

# AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=FinMate
TELEGRAM_PARSER_USE_OPENROUTER=true
TELEGRAM_PARSER_OPENROUTER_MODEL=openai/gpt-4o-mini
TELEGRAM_PARSER_OPENROUTER_COOLDOWN_MS=60000

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace-with-a-long-random-secret
TELEGRAM_LINK_CODE_TTL_SECONDS=600
TELEGRAM_PENDING_INTENT_TTL_SECONDS=900
TELEGRAM_PROCESSED_UPDATE_TTL_SECONDS=86400

# Rate limits
OTP_SEND_RATE_LIMIT_WINDOW_SECONDS=900
OTP_SEND_RATE_LIMIT_MAX=5
OTP_VERIFY_RATE_LIMIT_WINDOW_SECONDS=900
OTP_VERIFY_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_MAX=10
AI_SUMMARY_RATE_LIMIT_WINDOW_SECONDS=600
AI_SUMMARY_RATE_LIMIT_MAX=12
CHAT_RATE_LIMIT_WINDOW_SECONDS=600
CHAT_RATE_LIMIT_MAX=30
GOOGLE_CODE_EXCHANGE_RATE_LIMIT_WINDOW_SECONDS=900
GOOGLE_CODE_EXCHANGE_RATE_LIMIT_MAX=30
SUMMARY_SEND_RATE_LIMIT_WINDOW_SECONDS=900
SUMMARY_SEND_RATE_LIMIT_MAX=3

# Caching and chat
DASHBOARD_CACHE_TTL_SECONDS=60
AI_SUMMARY_FALLBACK_CACHE_TTL_SECONDS=600
CHAT_MESSAGE_MAX_LENGTH=500
CHAT_MEMORY_TTL_SECONDS=7200
CHAT_MEMORY_MAX_TURNS=6
CHAT_AI_HISTORY_MAX_TURNS=4

# Summary scheduler
SUMMARY_SCHEDULER_ENABLED=true
SUMMARY_SCHEDULER_INTERVAL_MS=60000
SUMMARY_DELIVERY_RETRY_COOLDOWN_MS=900000
SUMMARY_MANUAL_SEND_DEDUP_SECONDS=300
